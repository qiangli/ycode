.gfy-out/
#
# .agents is local agent scratch — ignored, EXCEPT the tracked
# contributor-skill lane at .agents/ycode/skills/ (see its README).
.agents/*
!.agents/ycode/
.agents/ycode/*
!.agents/ycode/skills/


# ycode local artifacts
.agents/ycode.json
.agents/ycode/settings.local.json
.agents/ycode/sessions/
.agents/ycode/cache/
.agents/ycode/logs/
.agents/ycode/foreman/

# Backlog kill-switch sentinel (runtime; backlog/*.md ARE tracked)
docs/backlog/PAUSE

# Claude Code per-project state — permission allowlist, scheduled-task
# locks, worktree state. Per-machine, contains absolute paths, not source.
.claude/
