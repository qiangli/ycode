# Binaries
/ycode
bin/
*.exe
*.dll
*.so
*.dylib

# Test binary
*.test

# Embedded inference runner — platform-specific build artifact produced by
# scripts/build-runner-thin.sh. Devs build locally when they want the
# embed_runner build tag; default builds use embed_stub.go and don't need it.
internal/inference/runner_embed/ycode-runner.gz

# Embedded container helper binaries — produced by scripts/embed-vfkit.sh,
# scripts/embed-gvproxy.sh, and scripts/embed-podman.sh (build from
# the Go module cache / external/podman submodule when no system
# binary is found). Same pattern as runner_embed: built locally,
# consumed only when the matching `embed_*` build tag is set.
internal/container/vfkit_embed/vfkit.gz
internal/container/gvproxy_embed/gvproxy.gz
internal/container/podman_embed/podman.gz

# Embedded ycode-spawn micro shim — produced by scripts/embed-spawn.sh
# (stdlib-only build from cmd/ycode-spawn; runs on every `make compile`
# via ensure-embeds). Same pattern as the embeds above.
internal/runtime/wrap/spawn_embed/ycode-spawn.gz

# Go build cache
/vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Debug
*.log
debug/

.env
.env.*

tmp/
priorart/
reference/
peers/
go.work.local
evals/results/
