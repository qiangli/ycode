# Pinned commit SHAs for sibling-path replace targets in go.mod
# (../sh, ../nadir, ../coreutils). script/bootstrap-siblings.sh reads this file
# and clones each missing sibling at the listed SHA, so standalone
# clones of ycode build without external setup.
#
# Inside the dhnt umbrella the siblings already exist as submodules
# (dhnt/sh, dhnt/nadir, dhnt/coreutils) — the bootstrap script detects them and
# leaves them alone, so there is still exactly one copy of each.
#
# Format: <name>=<sha>. When bumping a sibling in the umbrella's
# script/sync.sh, the SHA here must be bumped to match — sync.sh
# automates this.
sh=9ae93288c996894595e09688ada0698810d3a4ab
nadir=b7b02de0165c2670c8c810484c20088abd3e5de4
coreutils=89fc0d8fbf2459ccc777d595de24f3e5a0eecd8e
