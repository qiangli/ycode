[
  {
    "name": "ycode",
    "dashboards": [
      {
        "name": "LLM Overview",
        "panels": [
          {"title": "API Call Rate", "query": "rate(ycode_llm_call_total[5m])", "type": "timeseries"},
          {"title": "API Call Latency (p95)", "query": "histogram_quantile(0.95, rate(ycode_llm_call_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Estimated Cost ($)", "query": "sum(ycode_llm_cost_dollars) by (service_instance_id)", "type": "timeseries"},
          {"title": "Total Calls", "query": "sum(ycode_llm_call_total)", "type": "stat"}
        ]
      },
      {
        "name": "Token Usage",
        "panels": [
          {"title": "Input Tokens", "query": "rate(ycode_llm_tokens_input[5m])", "type": "timeseries"},
          {"title": "Output Tokens", "query": "rate(ycode_llm_tokens_output[5m])", "type": "timeseries"},
          {"title": "Cache Read Tokens", "query": "rate(ycode_llm_tokens_cache_read[5m])", "type": "timeseries"},
          {"title": "Cache Write Tokens", "query": "rate(ycode_llm_tokens_cache_write[5m])", "type": "timeseries"}
        ]
      },
      {
        "name": "Tool Performance",
        "panels": [
          {"title": "Tool Call Rate", "query": "rate(ycode_tool_call_total[5m])", "type": "timeseries"},
          {"title": "Tool Latency (p95)", "query": "histogram_quantile(0.95, rate(ycode_tool_call_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Top Tools by Call Count", "query": "topk(10, sum by (tool_name) (ycode_tool_call_total))", "type": "table"}
        ]
      },
      {
        "name": "Session Activity",
        "panels": [
          {"title": "Turns per Session", "query": "sum(ycode_session_turns) by (service_instance_id)", "type": "timeseries"},
          {"title": "Turn Duration (p95)", "query": "histogram_quantile(0.95, rate(ycode_turn_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Tools per Turn", "query": "histogram_quantile(0.5, rate(ycode_turn_tool_count_bucket[5m]))", "type": "timeseries"}
        ]
      },
      {
        "name": "Context & Compaction",
        "panels": [
          {"title": "Context Window Usage", "query": "ycode_llm_context_window_used", "type": "timeseries"},
          {"title": "Compaction Events", "query": "rate(ycode_compaction_total[5m])", "type": "timeseries"},
          {"title": "Tokens Saved by Compaction", "query": "sum(ycode_compaction_tokens_saved)", "type": "stat"}
        ]
      },
      {
        "name": "Per-Tool & Per-Project Rollup",
        "panels": [
          {"title": "LLM Calls by Agent Tool", "query": "sum by (ycode_agent_tool) (rate(ycode_llm_call_total[5m]))", "type": "timeseries"},
          {"title": "LLM Calls by Project", "query": "sum by (ycode_project_name) (rate(ycode_llm_call_total[5m]))", "type": "timeseries"},
          {"title": "Cost ($) by Agent Tool", "query": "sum by (ycode_agent_tool) (ycode_llm_cost_dollars)", "type": "timeseries"},
          {"title": "Cost ($) by Project", "query": "sum by (ycode_project_name) (ycode_llm_cost_dollars)", "type": "table"},
          {"title": "Tool Calls by Foreign Agent Client", "query": "sum by (ycode_agent_client) (rate(ycode_tool_call_total{ycode_agent_client!=\"\"}[5m]))", "type": "timeseries"},
          {"title": "Top Foreign Agents (Tool Volume)", "query": "topk(10, sum by (ycode_agent_client) (ycode_tool_call_total{ycode_agent_client!=\"\"}))", "type": "table"},
          {"title": "Errors by Project", "query": "sum by (ycode_project_name) (rate(ycode_error_total[5m]))", "type": "timeseries"},
          {"title": "Active Projects", "query": "count(count by (ycode_project_name) (rate(ycode_llm_call_total[5m]) > 0))", "type": "stat"},
          {"title": "Active Agent Tools", "query": "count(count by (ycode_agent_tool) (rate(ycode_llm_call_total[5m]) > 0))", "type": "stat"}
        ]
      },
      {
        "name": "Instance Comparison",
        "panels": [
          {"title": "Calls by Project + Instance", "query": "sum by (ycode_project_name, service_instance_id) (ycode_llm_call_total)", "type": "timeseries"},
          {"title": "Cost by Project + Instance", "query": "sum by (ycode_project_name, service_instance_id) (ycode_llm_cost_dollars)", "type": "timeseries"},
          {"title": "Tokens by Project + Instance", "query": "sum by (ycode_project_name, service_instance_id) (ycode_llm_tokens_input + ycode_llm_tokens_output)", "type": "timeseries"},
          {"title": "Top Projects (Call Volume)", "query": "topk(10, sum by (ycode_project_name) (ycode_llm_call_total))", "type": "table"}
        ]
      },
      {
        "name": "Ollama Inference",
        "panels": [
          {"title": "Runner Healthy", "query": "ycode_inference_runner_healthy", "type": "stat"},
          {"title": "Runner Restarts", "query": "ycode_inference_runner_restart_count", "type": "stat"},
          {"title": "Inference Call Rate", "query": "rate(ycode_inference_call_total[5m])", "type": "timeseries"},
          {"title": "Inference Latency (p95)", "query": "histogram_quantile(0.95, rate(ycode_inference_call_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Model Load Time (p99)", "query": "histogram_quantile(0.99, rate(ycode_inference_model_load_time_bucket[5m]))", "type": "timeseries"},
          {"title": "Input Tokens/s", "query": "rate(ycode_inference_tokens_input[5m])", "type": "timeseries"},
          {"title": "Output Tokens/s", "query": "rate(ycode_inference_tokens_output[5m])", "type": "timeseries"},
          {"title": "Runner Starts", "query": "sum(ycode_inference_runner_starts)", "type": "stat"},
          {"title": "Runner Crashes", "query": "sum(ycode_inference_runner_crashes)", "type": "stat"}
        ]
      },
      {
        "name": "API Health",
        "panels": [
          {"title": "API Errors Total", "query": "sum(ycode_api_error_total)", "type": "stat"},
          {"title": "API Error Rate", "query": "sum(rate(ycode_api_error_total[5m])) by (error_type)", "type": "timeseries"},
          {"title": "API Errors by Status Code", "query": "sum(rate(ycode_api_error_total[5m])) by (status_code)", "type": "timeseries"},
          {"title": "API Errors by Type", "query": "sum(ycode_api_error_total) by (error_type)", "type": "table"},
          {"title": "Message Structure Warnings", "query": "sum(rate(ycode_message_structure_warnings[5m])) by (warning_type)", "type": "timeseries"},
          {"title": "Orphan Tool Call Warnings", "query": "sum(ycode_message_structure_warnings{warning_type=\"orphan_tool_use\"})", "type": "stat"},
          {"title": "LLM Call Success Rate", "query": "1 - (sum(rate(ycode_api_error_total[5m])) / sum(rate(ycode_llm_call_total[5m])))", "type": "timeseries"},
          {"title": "Error vs Call Rate", "query": "sum(rate(ycode_api_error_total[5m]))", "type": "timeseries"}
        ]
      },
      {
        "name": "Pause & Resume",
        "panels": [
          {"title": "Pause Events", "query": "sum(ycode_pause_total)", "type": "stat"},
          {"title": "Resume Events", "query": "sum(ycode_resume_total)", "type": "stat"},
          {"title": "Pause Rate", "query": "rate(ycode_pause_total[5m])", "type": "timeseries"},
          {"title": "Pause Duration (p50)", "query": "histogram_quantile(0.5, rate(ycode_pause_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Pause Duration (p95)", "query": "histogram_quantile(0.95, rate(ycode_pause_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Pause vs API Errors", "query": "sum(rate(ycode_pause_total[5m])) or sum(rate(ycode_api_error_total[5m]))", "type": "timeseries"},
          {"title": "Avg Pause Duration (ms)", "query": "histogram_quantile(0.5, rate(ycode_pause_duration_bucket[5m]))", "type": "stat"}
        ]
      },
      {
        "name": "Error Overview",
        "panels": [
          {"title": "Total Errors", "query": "sum(ycode_error_total)", "type": "stat"},
          {"title": "Error Rate by Component", "query": "sum(rate(ycode_error_total[5m])) by (component)", "type": "timeseries"},
          {"title": "Error Rate by Type", "query": "sum(rate(ycode_error_total[5m])) by (error_type)", "type": "timeseries"},
          {"title": "Errors by Component", "query": "sum(ycode_error_total) by (component)", "type": "table"},
          {"title": "Errors by Type", "query": "sum(ycode_error_total) by (component, error_type)", "type": "table"},
          {"title": "Tool Errors", "query": "sum(rate(ycode_error_total{component=\"tool\"}[5m])) by (error_type)", "type": "timeseries"},
          {"title": "Conversation Errors", "query": "sum(rate(ycode_error_total{component=\"conversation\"}[5m])) by (error_type)", "type": "timeseries"},
          {"title": "All Error Signals", "query": "sum(rate(ycode_error_total[5m])) or sum(rate(ycode_api_error_total[5m])) or sum(rate(ycode_message_structure_warnings[5m]))", "type": "timeseries"}
        ]
      },
      {
        "name": "Session Health",
        "panels": [
          {"title": "Turn Duration p95 by Session", "query": "histogram_quantile(0.95, sum by (le, session_id) (rate(ycode_turn_duration_bucket[5m])))", "type": "timeseries"},
          {"title": "Tool Errors per Session", "query": "sum by (session_id) (rate(ycode_error_total{component=\"tool\"}[5m]))", "type": "timeseries"},
          {"title": "Tools per Turn (p50)", "query": "histogram_quantile(0.5, sum by (le, session_id) (rate(ycode_turn_tool_count_bucket[5m])))", "type": "timeseries"},
          {"title": "Active Sessions", "query": "count(count by (session_id) (rate(ycode_turn_duration_count[5m]) > 0))", "type": "stat"}
        ]
      },
      {
        "name": "Bash & Exec",
        "panels": [
          {"title": "Bash Exec Rate", "query": "sum(rate(ycode_bash_exec_total[5m]))", "type": "timeseries"},
          {"title": "Bash Exec by Success", "query": "sum by (success) (rate(ycode_bash_exec_total[5m]))", "type": "timeseries"},
          {"title": "Bash Latency p50", "query": "histogram_quantile(0.5, rate(ycode_bash_exec_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Bash Latency p95", "query": "histogram_quantile(0.95, rate(ycode_bash_exec_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Background Jobs", "query": "sum(ycode_bash_exec_total{background=\"true\"})", "type": "stat"},
          {"title": "Timeouts", "query": "sum(ycode_bash_exec_total{timed_out=\"true\"})", "type": "stat"},
          {"title": "Non-zero Exit Codes", "query": "sum by (exit_code) (ycode_bash_exec_total{success=\"false\"})", "type": "table"}
        ]
      },
      {
        "name": "Exec Activity",
        "panels": [
          {"title": "Exec Rate by Scope", "query": "sum by (scope) (rate(ycode_exec_total[5m]))", "type": "timeseries"},
          {"title": "Exit Class Distribution", "query": "sum by (exit_class) (rate(ycode_exec_total[5m]))", "type": "timeseries"},
          {"title": "Exec Latency p50 by Scope", "query": "histogram_quantile(0.5, sum by (le, scope) (rate(ycode_exec_duration_bucket[5m])))", "type": "timeseries"},
          {"title": "Exec Latency p95 by Scope", "query": "histogram_quantile(0.95, sum by (le, scope) (rate(ycode_exec_duration_bucket[5m])))", "type": "timeseries"},
          {"title": "Failures (non-zero exit_class)", "query": "sum by (scope, exit_class) (rate(ycode_exec_total{exit_class!=\"zero\"}[5m]))", "type": "table"},
          {"title": "Total Execs by Scope", "query": "sum by (scope) (ycode_exec_total)", "type": "table"},
          {"title": "Success Rate by Scope", "query": "sum by (scope) (rate(ycode_exec_total{success=\"true\"}[5m])) / sum by (scope) (rate(ycode_exec_total[5m]))", "type": "timeseries"}
        ]
      },
      {
        "name": "Container Operations",
        "panels": [
          {"title": "Active Containers", "query": "ycode_container_active", "type": "stat"},
          {"title": "Pool Available", "query": "ycode_container_pool_available", "type": "stat"},
          {"title": "Pool Total", "query": "ycode_container_pool_total", "type": "stat"},
          {"title": "Container Creates Rate", "query": "rate(ycode_container_creates[5m])", "type": "timeseries"},
          {"title": "Container Exec Rate", "query": "sum by (success) (rate(ycode_container_execs[5m]))", "type": "timeseries"},
          {"title": "Container Failures Rate", "query": "rate(ycode_container_failures[5m])", "type": "timeseries"},
          {"title": "Container Exec Latency p95", "query": "histogram_quantile(0.95, rate(ycode_container_exec_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Total Container Failures", "query": "sum(ycode_container_failures)", "type": "stat"}
        ]
      },
      {
        "name": "Browser Stack",
        "panels": [
          {"title": "Action Rate by Mode", "query": "sum by (mode) (rate(ycode_browser_action_total[5m]))", "type": "timeseries"},
          {"title": "Action Duration p95 by Mode", "query": "histogram_quantile(0.95, sum by (le, mode) (rate(ycode_browser_action_duration_bucket[5m])))", "type": "timeseries"},
          {"title": "Outcome Class Distribution", "query": "sum by (outcome) (rate(ycode_browser_action_total[5m]))", "type": "timeseries"},
          {"title": "Top Hint Engine Rules", "query": "topk(10, sum by (rule) (ycode_browser_hint_fired_total))", "type": "table"},
          {"title": "Circuit-Breaker Trips by Level", "query": "sum by (level) (rate(ycode_browser_breaker_trips_total[5m]))", "type": "timeseries"},
          {"title": "Ralph Strategy Success Rate", "query": "sum by (strategy) (rate(ycode_browser_ralph_attempts_total{succeeded=\"true\"}[5m])) / sum by (strategy) (rate(ycode_browser_ralph_attempts_total[5m]))", "type": "timeseries"},
          {"title": "Live Hub Extension Connections", "query": "ycode_browser_live_connections", "type": "stat"},
          {"title": "DOM Compression Ratio (p50)", "query": "histogram_quantile(0.5, rate(ycode_browser_dom_compression_ratio_bucket[5m]))", "type": "timeseries"}
        ]
      },
      {
        "name": "Shell Builtin Dispatch",
        "panels": [
          {"title": "yc <verb> Call Rate", "query": "sum by (verb) (rate(ycode_shell_builtin_total[5m]))", "type": "timeseries"},
          {"title": "Verb Success Rate", "query": "sum by (verb) (rate(ycode_shell_builtin_total{success=\"true\"}[5m])) / sum by (verb) (rate(ycode_shell_builtin_total[5m]))", "type": "timeseries"},
          {"title": "Verb Latency p95", "query": "histogram_quantile(0.95, sum by (le, verb) (rate(ycode_shell_builtin_duration_bucket[5m])))", "type": "timeseries"},
          {"title": "Top Verbs by Call Volume", "query": "topk(10, sum by (verb) (ycode_shell_builtin_total))", "type": "table"},
          {"title": "Hint Engine Firings by Rule", "query": "sum by (hint_id) (rate(ycode_shell_hints_fired_total[5m]))", "type": "timeseries"},
          {"title": "Hint Firings by Phase", "query": "sum by (phase) (rate(ycode_shell_hints_fired_total[5m]))", "type": "timeseries"},
          {"title": "Intent Classification Distribution", "query": "sum by (kind) (rate(ycode_shell_intent_classified_total[5m]))", "type": "timeseries"},
          {"title": "Shell Command Dispatch Latency p95", "query": "histogram_quantile(0.95, rate(ycode_shell_command_duration_bucket[5m]))", "type": "timeseries"}
        ]
      },
      {
        "name": "File Ops",
        "panels": [
          {"title": "File Ops Rate", "query": "sum by (op) (rate(ycode_fileops_ops_total[5m]))", "type": "timeseries"},
          {"title": "File Ops by Op", "query": "sum by (op) (ycode_fileops_ops_total)", "type": "table"},
          {"title": "Failed Ops", "query": "sum by (op) (rate(ycode_fileops_ops_total{success=\"false\"}[5m]))", "type": "timeseries"},
          {"title": "Bytes Throughput", "query": "sum by (op) (rate(ycode_fileops_bytes_total[5m]))", "type": "timeseries"},
          {"title": "Total Bytes Read", "query": "sum(ycode_fileops_bytes_total{op=\"read\"})", "type": "stat"},
          {"title": "Total Bytes Written", "query": "sum(ycode_fileops_bytes_total{op=\"write\"})", "type": "stat"}
        ]
      },
      {
        "name": "HTTP Outbound & Retries",
        "panels": [
          {"title": "HTTP Request Rate by Host", "query": "sum by (http_host) (rate(ycode_http_request_total[5m]))", "type": "timeseries"},
          {"title": "HTTP Latency p95", "query": "histogram_quantile(0.95, rate(ycode_http_request_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "HTTP Status Mix", "query": "sum by (http_status_code) (rate(ycode_http_request_total[5m]))", "type": "timeseries"},
          {"title": "HTTP Failures", "query": "sum(rate(ycode_http_request_total{success=\"false\"}[5m]))", "type": "timeseries"},
          {"title": "Retry Attempts Rate", "query": "sum by (reason) (rate(ycode_api_retry_attempts[5m]))", "type": "timeseries"},
          {"title": "Retry Backoff p50 (ms)", "query": "histogram_quantile(0.5, rate(ycode_api_retry_delay_bucket[5m]))", "type": "timeseries"},
          {"title": "Retry Reasons", "query": "sum by (reason) (ycode_api_retry_attempts)", "type": "table"}
        ]
      },
      {
        "name": "Web Tools",
        "panels": [
          {"title": "Web Fetch Rate", "query": "sum(rate(ycode_web_fetch_total[5m]))", "type": "timeseries"},
          {"title": "Web Fetch by Host", "query": "sum by (host) (ycode_web_fetch_total)", "type": "table"},
          {"title": "Web Fetch Latency p95", "query": "histogram_quantile(0.95, rate(ycode_web_fetch_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Web Fetch Failures", "query": "sum(rate(ycode_web_fetch_total{success=\"false\"}[5m]))", "type": "timeseries"},
          {"title": "Web Search Rate", "query": "sum(rate(ycode_web_search_total[5m]))", "type": "timeseries"},
          {"title": "Web Search Latency p95", "query": "histogram_quantile(0.95, rate(ycode_web_search_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Web Search Results (median)", "query": "histogram_quantile(0.5, rate(ycode_web_search_results_bucket[5m]))", "type": "timeseries"}
        ]
      },
      {
        "name": "Panics",
        "panels": [
          {"title": "Total Panics", "query": "sum(ycode_runtime_panic_total)", "type": "stat"},
          {"title": "Panic Rate", "query": "sum(rate(ycode_runtime_panic_total[5m]))", "type": "timeseries"},
          {"title": "Panics by Component", "query": "sum by (component) (ycode_runtime_panic_total)", "type": "table"},
          {"title": "Panics by Detail (top 10)", "query": "topk(10, sum by (detail) (ycode_runtime_panic_total))", "type": "table"}
        ]
      }
    ]
  },
  {
    "name": "host-metrics",
    "dashboards": [
      {
        "name": "Host Information",
        "panels": [
          {"title": "CPU Load Average (1m / 5m / 15m)", "query": "system_cpu_load_average_1m", "type": "timeseries"},
          {"title": "Total Processes", "query": "system_processes_count", "type": "stat"},
          {"title": "Memory Total (bytes)", "query": "sum(system_memory_usage_bytes)", "type": "stat"},
          {"title": "Filesystem Total (bytes)", "query": "sum(system_filesystem_usage_bytes) by (mountpoint)", "type": "table"}
        ]
      },
      {
        "name": "CPU",
        "panels": [
          {"title": "CPU Time by State", "query": "rate(system_cpu_time_seconds_total[5m])", "type": "timeseries"},
          {"title": "CPU User Time", "query": "sum(rate(system_cpu_time_seconds_total{state=\"user\"}[5m]))", "type": "timeseries"},
          {"title": "CPU System Time", "query": "sum(rate(system_cpu_time_seconds_total{state=\"system\"}[5m]))", "type": "timeseries"},
          {"title": "CPU Idle Time", "query": "sum(rate(system_cpu_time_seconds_total{state=\"idle\"}[5m]))", "type": "timeseries"},
          {"title": "Load Average 1m", "query": "system_cpu_load_average_1m", "type": "timeseries"},
          {"title": "Load Average 5m", "query": "system_cpu_load_average_5m", "type": "timeseries"},
          {"title": "Load Average 15m", "query": "system_cpu_load_average_15m", "type": "timeseries"}
        ]
      },
      {
        "name": "Memory",
        "panels": [
          {"title": "Memory Usage by State", "query": "system_memory_usage_bytes", "type": "timeseries"},
          {"title": "Used Memory", "query": "system_memory_usage_bytes{state=\"used\"}", "type": "timeseries"},
          {"title": "Free Memory", "query": "system_memory_usage_bytes{state=\"free\"}", "type": "timeseries"},
          {"title": "Cached Memory", "query": "system_memory_usage_bytes{state=\"cached\"}", "type": "timeseries"},
          {"title": "Paging Usage", "query": "system_paging_usage_bytes", "type": "timeseries"},
          {"title": "Paging Operations", "query": "rate(system_paging_operations_total[5m])", "type": "timeseries"}
        ]
      },
      {
        "name": "Disk",
        "panels": [
          {"title": "Disk Read I/O", "query": "rate(system_disk_io_bytes_total{direction=\"read\"}[5m])", "type": "timeseries"},
          {"title": "Disk Write I/O", "query": "rate(system_disk_io_bytes_total{direction=\"write\"}[5m])", "type": "timeseries"},
          {"title": "Disk Read Operations", "query": "rate(system_disk_operations_total{direction=\"read\"}[5m])", "type": "timeseries"},
          {"title": "Disk Write Operations", "query": "rate(system_disk_operations_total{direction=\"write\"}[5m])", "type": "timeseries"},
          {"title": "Filesystem Usage by Mountpoint", "query": "system_filesystem_usage_bytes{state=\"used\"}", "type": "timeseries"},
          {"title": "Filesystem Free by Mountpoint", "query": "system_filesystem_usage_bytes{state=\"free\"}", "type": "timeseries"}
        ]
      },
      {
        "name": "Network",
        "panels": [
          {"title": "Network Receive Rate", "query": "rate(system_network_io_bytes_total{direction=\"receive\"}[5m])", "type": "timeseries"},
          {"title": "Network Transmit Rate", "query": "rate(system_network_io_bytes_total{direction=\"transmit\"}[5m])", "type": "timeseries"},
          {"title": "Network Connections", "query": "system_network_connections", "type": "timeseries"},
          {"title": "Network Errors (Receive)", "query": "rate(system_network_errors_total{direction=\"receive\"}[5m])", "type": "timeseries"},
          {"title": "Network Errors (Transmit)", "query": "rate(system_network_errors_total{direction=\"transmit\"}[5m])", "type": "timeseries"},
          {"title": "Network Packets (Receive)", "query": "rate(system_network_packets_total{direction=\"receive\"}[5m])", "type": "timeseries"},
          {"title": "Network Packets (Transmit)", "query": "rate(system_network_packets_total{direction=\"transmit\"}[5m])", "type": "timeseries"}
        ]
      }
    ]
  }
]
