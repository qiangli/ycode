[
  {
    "name": "ycode",
    "dashboards": [
      {
        "name": "LLM Overview",
        "panels": [
          {"title": "API Call Rate", "query": "rate(ycode_llm_call_total[5m])", "type": "timeseries"},
          {"title": "API Call Latency (p95)", "query": "histogram_quantile(0.95, rate(ycode_llm_call_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Estimated Cost ($)", "query": "sum(ycode_llm_cost_dollars) by (service_instance_id)", "type": "timeseries"},
          {"title": "Total Calls", "query": "sum(ycode_llm_call_total)", "type": "stat"}
        ]
      },
      {
        "name": "Token Usage",
        "panels": [
          {"title": "Input Tokens", "query": "rate(ycode_llm_tokens_input[5m])", "type": "timeseries"},
          {"title": "Output Tokens", "query": "rate(ycode_llm_tokens_output[5m])", "type": "timeseries"},
          {"title": "Cache Read Tokens", "query": "rate(ycode_llm_tokens_cache_read[5m])", "type": "timeseries"},
          {"title": "Cache Write Tokens", "query": "rate(ycode_llm_tokens_cache_write[5m])", "type": "timeseries"}
        ]
      },
      {
        "name": "Tool Performance",
        "panels": [
          {"title": "Tool Call Rate", "query": "rate(ycode_tool_call_total[5m])", "type": "timeseries"},
          {"title": "Tool Latency (p95)", "query": "histogram_quantile(0.95, rate(ycode_tool_call_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Top Tools by Call Count", "query": "topk(10, sum by (tool_name) (ycode_tool_call_total))", "type": "table"}
        ]
      },
      {
        "name": "Session Activity",
        "panels": [
          {"title": "Turns per Session", "query": "sum(ycode_session_turns) by (service_instance_id)", "type": "timeseries"},
          {"title": "Session Cost ($)", "query": "sum(ycode_session_cost) by (service_instance_id)", "type": "timeseries"},
          {"title": "Session Tokens", "query": "sum(ycode_session_tokens_input + ycode_session_tokens_output) by (service_instance_id)", "type": "timeseries"},
          {"title": "Turn Duration (p95)", "query": "histogram_quantile(0.95, rate(ycode_turn_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Files Changed per Turn", "query": "histogram_quantile(0.5, rate(ycode_turn_files_changed_bucket[5m]))", "type": "timeseries"},
          {"title": "Tools per Turn", "query": "histogram_quantile(0.5, rate(ycode_turn_tool_count_bucket[5m]))", "type": "timeseries"}
        ]
      },
      {
        "name": "Context & Compaction",
        "panels": [
          {"title": "Context Window Usage", "query": "ycode_llm_context_window_used", "type": "timeseries"},
          {"title": "Compaction Events", "query": "rate(ycode_compaction_total[5m])", "type": "timeseries"},
          {"title": "Tokens Saved by Compaction", "query": "sum(ycode_compaction_tokens_saved)", "type": "stat"}
        ]
      },
      {
        "name": "Instance Comparison",
        "panels": [
          {"title": "Calls by Instance", "query": "sum by (service_instance_id) (ycode_llm_call_total)", "type": "timeseries"},
          {"title": "Cost by Instance", "query": "sum by (service_instance_id) (ycode_llm_cost_dollars)", "type": "timeseries"},
          {"title": "Tokens by Instance", "query": "sum by (service_instance_id) (ycode_llm_tokens_input + ycode_llm_tokens_output)", "type": "timeseries"}
        ]
      }
    ]
  },
  {
    "name": "host-metrics",
    "dashboards": [
      {
        "name": "Host Information",
        "panels": [
          {"title": "CPU Load Average (1m / 5m / 15m)", "query": "system_cpu_load_average_1m", "type": "timeseries"},
          {"title": "Total Processes", "query": "system_processes_count", "type": "stat"},
          {"title": "Memory Total (bytes)", "query": "sum(system_memory_usage_bytes)", "type": "stat"},
          {"title": "Filesystem Total (bytes)", "query": "sum(system_filesystem_usage_bytes) by (mountpoint)", "type": "table"}
        ]
      },
      {
        "name": "CPU",
        "panels": [
          {"title": "CPU Time by State", "query": "rate(system_cpu_time_seconds_total[5m])", "type": "timeseries"},
          {"title": "CPU User Time", "query": "sum(rate(system_cpu_time_seconds_total{state=\"user\"}[5m]))", "type": "timeseries"},
          {"title": "CPU System Time", "query": "sum(rate(system_cpu_time_seconds_total{state=\"system\"}[5m]))", "type": "timeseries"},
          {"title": "CPU Idle Time", "query": "sum(rate(system_cpu_time_seconds_total{state=\"idle\"}[5m]))", "type": "timeseries"},
          {"title": "Load Average 1m", "query": "system_cpu_load_average_1m", "type": "timeseries"},
          {"title": "Load Average 5m", "query": "system_cpu_load_average_5m", "type": "timeseries"},
          {"title": "Load Average 15m", "query": "system_cpu_load_average_15m", "type": "timeseries"}
        ]
      },
      {
        "name": "Memory",
        "panels": [
          {"title": "Memory Usage by State", "query": "system_memory_usage_bytes", "type": "timeseries"},
          {"title": "Used Memory", "query": "system_memory_usage_bytes{state=\"used\"}", "type": "timeseries"},
          {"title": "Free Memory", "query": "system_memory_usage_bytes{state=\"free\"}", "type": "timeseries"},
          {"title": "Cached Memory", "query": "system_memory_usage_bytes{state=\"cached\"}", "type": "timeseries"},
          {"title": "Paging Usage", "query": "system_paging_usage_bytes", "type": "timeseries"},
          {"title": "Paging Operations", "query": "rate(system_paging_operations_total[5m])", "type": "timeseries"}
        ]
      },
      {
        "name": "Disk",
        "panels": [
          {"title": "Disk Read I/O", "query": "rate(system_disk_io_bytes_total{direction=\"read\"}[5m])", "type": "timeseries"},
          {"title": "Disk Write I/O", "query": "rate(system_disk_io_bytes_total{direction=\"write\"}[5m])", "type": "timeseries"},
          {"title": "Disk Read Operations", "query": "rate(system_disk_operations_total{direction=\"read\"}[5m])", "type": "timeseries"},
          {"title": "Disk Write Operations", "query": "rate(system_disk_operations_total{direction=\"write\"}[5m])", "type": "timeseries"},
          {"title": "Filesystem Usage by Mountpoint", "query": "system_filesystem_usage_bytes{state=\"used\"}", "type": "timeseries"},
          {"title": "Filesystem Free by Mountpoint", "query": "system_filesystem_usage_bytes{state=\"free\"}", "type": "timeseries"}
        ]
      },
      {
        "name": "Network",
        "panels": [
          {"title": "Network Receive Rate", "query": "rate(system_network_io_bytes_total{direction=\"receive\"}[5m])", "type": "timeseries"},
          {"title": "Network Transmit Rate", "query": "rate(system_network_io_bytes_total{direction=\"transmit\"}[5m])", "type": "timeseries"},
          {"title": "Network Connections", "query": "system_network_connections", "type": "timeseries"},
          {"title": "Network Errors (Receive)", "query": "rate(system_network_errors_total{direction=\"receive\"}[5m])", "type": "timeseries"},
          {"title": "Network Errors (Transmit)", "query": "rate(system_network_errors_total{direction=\"transmit\"}[5m])", "type": "timeseries"},
          {"title": "Network Packets (Receive)", "query": "rate(system_network_packets_total{direction=\"receive\"}[5m])", "type": "timeseries"},
          {"title": "Network Packets (Transmit)", "query": "rate(system_network_packets_total{direction=\"transmit\"}[5m])", "type": "timeseries"}
        ]
      }
    ]
  },
  {
    "name": "ycode-node-collector",
    "dashboards": [
      {
        "name": "LLM Metrics",
        "panels": [
          {"title": "LLM Call Rate", "query": "rate(ycode_llm_call_total[5m])", "type": "timeseries"},
          {"title": "LLM Call Latency (p50)", "query": "histogram_quantile(0.5, rate(ycode_llm_call_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "LLM Call Latency (p95)", "query": "histogram_quantile(0.95, rate(ycode_llm_call_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "LLM Call Latency (p99)", "query": "histogram_quantile(0.99, rate(ycode_llm_call_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Total LLM Calls", "query": "sum(ycode_llm_call_total) by (llm_model)", "type": "table"},
          {"title": "Cost by Model ($)", "query": "sum(ycode_llm_cost_dollars) by (llm_model)", "type": "timeseries"},
          {"title": "Cumulative Cost ($)", "query": "sum(ycode_llm_cost_dollars)", "type": "stat"},
          {"title": "Context Window Used", "query": "ycode_llm_context_window_used", "type": "timeseries"}
        ]
      },
      {
        "name": "Token Metrics",
        "panels": [
          {"title": "Input Token Rate", "query": "rate(ycode_llm_tokens_input[5m])", "type": "timeseries"},
          {"title": "Output Token Rate", "query": "rate(ycode_llm_tokens_output[5m])", "type": "timeseries"},
          {"title": "Cache Read Token Rate", "query": "rate(ycode_llm_tokens_cache_read[5m])", "type": "timeseries"},
          {"title": "Cache Write Token Rate", "query": "rate(ycode_llm_tokens_cache_write[5m])", "type": "timeseries"},
          {"title": "Total Input Tokens", "query": "sum(ycode_llm_tokens_input) by (llm_model)", "type": "table"},
          {"title": "Total Output Tokens", "query": "sum(ycode_llm_tokens_output) by (llm_model)", "type": "table"},
          {"title": "Cache Hit Ratio", "query": "sum(rate(ycode_llm_tokens_cache_read[5m])) / (sum(rate(ycode_llm_tokens_input[5m])) + sum(rate(ycode_llm_tokens_cache_read[5m])))", "type": "timeseries"}
        ]
      },
      {
        "name": "Tool Metrics",
        "panels": [
          {"title": "Tool Call Rate", "query": "sum(rate(ycode_tool_call_total[5m])) by (tool_name)", "type": "timeseries"},
          {"title": "Tool Latency (p50)", "query": "histogram_quantile(0.5, sum(rate(ycode_tool_call_duration_bucket[5m])) by (le, tool_name))", "type": "timeseries"},
          {"title": "Tool Latency (p95)", "query": "histogram_quantile(0.95, sum(rate(ycode_tool_call_duration_bucket[5m])) by (le, tool_name))", "type": "timeseries"},
          {"title": "Tool Latency (p99)", "query": "histogram_quantile(0.99, sum(rate(ycode_tool_call_duration_bucket[5m])) by (le, tool_name))", "type": "timeseries"},
          {"title": "Top 10 Tools by Call Count", "query": "topk(10, sum by (tool_name) (ycode_tool_call_total))", "type": "table"},
          {"title": "Tool Error Rate", "query": "sum(rate(ycode_tool_call_total{tool_success=\"false\"}[5m])) by (tool_name)", "type": "timeseries"}
        ]
      },
      {
        "name": "Session & Turn Metrics",
        "panels": [
          {"title": "Turns per Session", "query": "sum(ycode_session_turns) by (service_instance_id)", "type": "timeseries"},
          {"title": "Session Duration (p50)", "query": "histogram_quantile(0.5, rate(ycode_session_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Session Cost ($)", "query": "sum(ycode_session_cost) by (service_instance_id)", "type": "timeseries"},
          {"title": "Session Input Tokens", "query": "sum(ycode_session_tokens_input) by (service_instance_id)", "type": "timeseries"},
          {"title": "Session Output Tokens", "query": "sum(ycode_session_tokens_output) by (service_instance_id)", "type": "timeseries"},
          {"title": "Turn Duration (p50)", "query": "histogram_quantile(0.5, rate(ycode_turn_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Turn Duration (p95)", "query": "histogram_quantile(0.95, rate(ycode_turn_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Turn Duration (p99)", "query": "histogram_quantile(0.99, rate(ycode_turn_duration_bucket[5m]))", "type": "timeseries"},
          {"title": "Files Changed per Turn", "query": "histogram_quantile(0.5, rate(ycode_turn_files_changed_bucket[5m]))", "type": "timeseries"},
          {"title": "Lines Added per Turn", "query": "histogram_quantile(0.5, rate(ycode_turn_lines_added_bucket[5m]))", "type": "timeseries"},
          {"title": "Lines Deleted per Turn", "query": "histogram_quantile(0.5, rate(ycode_turn_lines_deleted_bucket[5m]))", "type": "timeseries"},
          {"title": "Tools per Turn (median)", "query": "histogram_quantile(0.5, rate(ycode_turn_tool_count_bucket[5m]))", "type": "timeseries"},
          {"title": "Tools per Turn (p95)", "query": "histogram_quantile(0.95, rate(ycode_turn_tool_count_bucket[5m]))", "type": "timeseries"}
        ]
      },
      {
        "name": "Compaction Metrics",
        "panels": [
          {"title": "Compaction Rate", "query": "rate(ycode_compaction_total[5m])", "type": "timeseries"},
          {"title": "Total Compaction Events", "query": "sum(ycode_compaction_total)", "type": "stat"},
          {"title": "Tokens Saved Rate", "query": "rate(ycode_compaction_tokens_saved[5m])", "type": "timeseries"},
          {"title": "Total Tokens Saved", "query": "sum(ycode_compaction_tokens_saved)", "type": "stat"},
          {"title": "Context Window vs Compaction", "query": "ycode_llm_context_window_used", "type": "timeseries"}
        ]
      }
    ]
  }
]
